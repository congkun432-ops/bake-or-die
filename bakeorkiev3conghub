local function BugInteract(targetPos)
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.CFrame = CFrame.new(targetPos) + Vector3.new(0, 3, 0)
    task.wait(0.3)
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            local parent = v.Parent
            local pos = parent:IsA("Model") and (parent.PrimaryPart and parent.PrimaryPart.Position) or (parent:IsA("BasePart") and parent.Position)
            
            if pos and (pos - hrp.Position).Magnitude < 20 then
                v.HoldDuration = 0 
                fireproximityprompt(v)
                return true
            end
        end
    end
    return false
end

local function RunGoldBugPath()
    task.spawn(function()
        NotifyOn("six seven", "Đang đi lấy mã code...")
        for _, pos in pairs(BugCoords.CodePositions) do
            if not _G.GoldBugActive then return end
            BugInteract(pos)
            task.wait(0.3)
        end
        if not _G.GoldBugActive then return end
        NotifyOn("six seven", "Đang mở UI Ngân hàng...")
        BugInteract(BugCoords.FinalPos)
        task.wait(1.2)
        for i, pos in pairs(BugCoords.FarmPoints) do
            if not _G.GoldBugActive then return end
            NotifyOn("six seven", "Farm nhồi Bug tại điểm #"..i)
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = CFrame.new(pos) end
            for t = 5, 1, -1 do
                if not _G.GoldBugActive then break end
                task.wait(1)
            end
        end
        if not _G.GoldBugActive then return end
        NotifyOn("six seven", "chua nhập mã thì chịu")
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = CFrame.new(BugCoords.FinalPos) end
        
        _G.GoldBugActive = false
    end)
end
AddToggle("Auto Gold Bug", Tab_Auto, function(state)
    _G.GoldBugActive = state
    if state then
        RunGoldBugPath()
    end
end)

