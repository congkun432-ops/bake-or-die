                        end
                    end
                else
                    skippedForToday = false
                    if (RootPart.Position - POS_TREO).Magnitude > 5 then
                        RootPart.CFrame = CFrame.new(POS_TREO)
                    end
                end
                task.wait(0.5)
            end
        end)
    end
end)
