local lp = game.Players.LocalPlayer

local BlueprintSequence = {
    {Type = "Farm", Pos = Vector3.new(-432.01, 82.23, -35.68)},
    {Type = "Farm", Pos = Vector3.new(-118.78, 67.92, -167.74)}, 
    {Type = "Collect", Pos = Vector3.new(-142.67, 53.77, -211.52)}, 
    {Type = "Farm", Pos = Vector3.new(251.28, 68.51, -23.98)}, 
    {Type = "Collect", Pos = Vector3.new(229.28, 51.85, -33.03)}, 
    {Type = "Farm", Pos = Vector3.new(627.25, 66.60, -185.59)}, 
    {Type = "Collect", Pos = Vector3.new(657.27, 68.38, -179.39)}, 
    {Type = "Collect", Pos = Vector3.new(667.93, 56.22, -134.54)}, 
    {Type = "Farm", Pos = Vector3.new(688.43, 66.78, 242.20)}, 
    {Type = "Collect", Pos = Vector3.new(690.56, 66.78, 273.21)}, 
    {Type = "Collect", Pos = Vector3.new(456.61, 55.92, -597.25)}, 
    {Type = "Farm", Pos = Vector3.new(989.22, 81.00, -126.43)}, 
    {Type = "GetCode", Pos = {Vector3.new(981.03, 54.10, -162.96), Vector3.new(983.45, 54.10, -93.26)}}, 
    {Type = "Final", Pos = Vector3.new(1037.90, 65.60, -126.34)} 
}

local function GetEnemies(radius)
    local count = 0
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return 0, nil end

    local firstEnemy = nil
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") and obj:FindFirstChildOfClass("Humanoid") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum.Health > 0 then
                local name = obj.Name
                if not (name:find("Farmer") or name:find("Builder") or name:find("Civilian")) then
                    local dist = (myRoot.Position - obj.HumanoidRootPart.Position).Magnitude
                    if dist <= radius then
                        count = count + 1
                        if not firstEnemy then firstEnemy = obj end
                    end
                end
            end
        end
    end
    return count, firstEnemy
end

task.spawn(function()
    while true do
        task.wait(1)
        if not _G.AutoBlueprintMaster then continue end
        
        _G.AutoFarm = true 
        
        local currentIndex = 1
        while _G.AutoBlueprintMaster and currentIndex <= #BlueprintSequence do
            local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(1) continue end
            if NotifyOn then
                NotifyOn("Processing", "Đang xử lý tọa độ: " .. currentIndex)
            end

            local Step = BlueprintSequence[currentIndex]
            local targetPos = (typeof(Step.Pos) == "table") and Step.Pos[1] or Step.Pos
            
            root.CFrame = CFrame.new(targetPos)
            task.wait(currentIndex == 1 and 2 or 1)
            
            if Step.Type == "Farm" then
                if currentIndex == 1 then
                    local _, enemy = GetEnemies(100)
                    if enemy and enemy:FindFirstChild("HumanoidRootPart") then
                        local hum = enemy.Humanoid
                        local pullTime = tick()
                        while hum and hum.Health > 0 and (tick() - pullTime < 5) and _G.AutoBlueprintMaster do
                            enemy.HumanoidRootPart.CFrame = root.CFrame * CFrame.new(0, 0, -5)
                            task.wait(0.1)
                        end
                    end
                else
                    local startTime = tick()
                    repeat
                        local enemyCount, _ = GetEnemies(100)
                        task.wait(1)
                    until enemyCount == 0 or (tick() - startTime > 15) or not _G.AutoBlueprintMaster
                end
                
            elseif Step.Type == "Collect" or Step.Type == "Final" or Step.Type == "GetCode" then
                local positions = (typeof(Step.Pos) == "table") and Step.Pos or {Step.Pos}
                for _, p in pairs(positions) do
                    root.CFrame = CFrame.new(p)
                    task.wait(0.8)
                    for _, v in pairs(workspace:GetDescendants()) do
                        if v:IsA("ProximityPrompt") then
                            if (v.Parent:IsA("BasePart") and (v.Parent.Position - root.Position).Magnitude < 30) then
                                v.HoldDuration = 0
                                fireproximityprompt(v)
                            end
                        end
                    end
                    task.wait(Step.Type == "GetCode" and 1.5 or 2.5)
                end
            end
            
            currentIndex = currentIndex + 1
            task.wait(0.5)
        end
        _G.AutoBlueprintMaster = false
        _G.AutoFarm = false
        if NotifyOn then
            NotifyOn("Done", "Đã hoàn thành bản thiết kế!")
        end
    end
end)

