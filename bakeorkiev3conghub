local POS_SKIP = Vector3.new(-37.91, 51.59, 86.33)
local POS_TREO = Vector3.new(-26.95, 85.49, 122.67)

local function ClickSkip()
    for _, v in pairs(workspace:GetDescendants()) do
        if (v:IsA("ProximityPrompt") or v:IsA("ClickDetector")) then
            local parent = v.Parent
            if parent:IsA("BasePart") and (parent.Position - POS_SKIP).Magnitude < 15 then
                if v:IsA("ProximityPrompt") then
                    fireproximityprompt(v)
                else
                    fireclickdetector(v)
                end
                return true
            end
        end
    end
    return false
end

AddToggle("auto days", Tab_Auto , function(s)
    _G.AutoLoopActive = s
    if _G.AutoLoopActive then
        task.spawn(function()
            local skippedForToday = false
            while _G.AutoLoopActive do
                local hour = Lighting.ClockTime
                if hour >= 6 and hour < 18 then
                    if not skippedForToday then
                        RootPart.CFrame = CFrame.new(POS_SKIP)
                        task.wait(0.4)
                        if ClickSkip() then
                            skippedForToday = true
                            RootPart.CFrame = CFrame.new(POS_TREO)
