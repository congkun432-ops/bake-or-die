    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = obj
end

local function RemoveESP(obj)
    local esp = obj:FindFirstChild("CongESP")
    local tag = obj:FindFirstChild("CongTag")
    if esp then esp:Destroy() end
