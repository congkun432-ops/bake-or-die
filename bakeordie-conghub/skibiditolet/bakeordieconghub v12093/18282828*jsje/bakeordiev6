local function IsInWhitelist(objName)
    local cleanedName = objName:lower()
    for _, whiteName in pairs(_G.MaterialWhitelist) do
        if cleanedName == whiteName:lower() then
            return true
        end
    end
    return false
end

local function IsTargetMob(objName)
    local cleanedObjName = objName:lower():gsub("%s+", "") 
    return TargetMobs[cleanedObjName] or false
end

local function BringToPosition(obj, targetCFrame)
    pcall(function()
        local prompt = obj:FindFirstChildOfClass("ProximityPrompt") or obj:FindFirstChild("Prompt", true)

        if obj:IsA("Model") then
            if obj.PrimaryPart then
                obj.PrimaryPart.CFrame = targetCFrame + Vector3.new(0, 1, 0)
            else
                obj:MoveTo(targetCFrame.Position) 
            end
        else
            obj.Anchored = false
            obj.CanCollide = false
            obj.CFrame = targetCFrame + Vector3.new(0, 1, 0) 
        end

        if prompt then
            task.spawn(function()
                fireproximityprompt(prompt)
            end)
        end
    end)
end

