local function GetEnemies(radius)
    local count = 0
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return 0, nil end

    local firstEnemy = nil
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") and obj:FindFirstChildOfClass("Humanoid") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum.Health > 0 then
                local name = obj.Name
                if not (name:find("Farmer") or name:find("Builder") or name:find("Civilian")) then
                    local dist = (myRoot.Position - obj.HumanoidRootPart.Position).Magnitude
                    if dist <= radius then
                        count = count + 1
                        if not firstEnemy then firstEnemy = obj end
                    end
                end
            end
        end
    end
    return count, firstEnemy
end

task.spawn(function()
    while true do
        task.wait(1)
        if not _G.AutoBlueprintMaster then continue end
        
        _G.AutoFarm = true 
        
        local currentIndex = 1
        while _G.AutoBlueprintMaster and currentIndex <= #BlueprintSequence do
            local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(1) continue end
            if NotifyOn then
                NotifyOn("Processing", "Đang xử lý tọa độ: " .. currentIndex)
            end

            local Step = BlueprintSequence[currentIndex]
            local targetPos = (typeof(Step.Pos) == "table") and Step.Pos[1] or Step.Pos
            
            root.CFrame = CFrame.new(targetPos)
            
            -- [BẮT BUỘC CHỜ 5 GIÂY] 
            -- Đến điểm nào cũng sẽ đứng im tại chỗ đúng 5 giây để Kill Aura đấm quái ổn định
            task.wait(5) 
            
            -- Sau khi chờ đủ 5 giây, kiểm tra lại xem bãi đã sạch quái chưa
            local startTime = tick()
            repeat
                local enemyCount, _ = GetEnemies(100) 
                task.wait(0.1) 
            -- Nếu sau 5 giây vẫn còn quái, nó sẽ đợi đập tiếp (tối đa thêm 7 giây nữa để tránh kẹt bài)
            until enemyCount == 0 or (tick() - startTime > 7) or not _G.AutoBlueprintMaster

            -- Nếu là điểm nhặt đồ thì tiến hành gom đồ sau khi đã xử lý xong quái
            if Step.Type == "Collect" or Step.Type == "Final" or Step.Type == "GetCode" then
                local positions = (typeof(Step.Pos) == "table") and Step.Pos or {Step.Pos}
                for _, p in pairs(positions) do
                    root.CFrame = CFrame.new(p)
                    task.wait(0.2) 
                    
                    for _, v in pairs(workspace:GetDescendants()) do
                        if v:IsA("ProximityPrompt") then
