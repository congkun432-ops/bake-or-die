local function T(key)
    return Languages[_G.CurrentLanguage][key] or key
end
local TranslatableElements = {}

local function RefreshLanguage()
    for element, data in pairs(TranslatableElements) do
        if element and element.Parent then
            pcall(function()
                if element:IsA("TextLabel") then
                    element.Text = T(data.key)
                end
            end)
        end
    end
end

