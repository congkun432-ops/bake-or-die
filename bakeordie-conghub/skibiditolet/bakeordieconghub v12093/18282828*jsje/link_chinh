local function countMonstersNearby(centerPos)
    local count = 0
    if MonstersFolder then
        for _, monster in ipairs(MonstersFolder:GetChildren()) do
            local mHrp = monster:FindFirstChild("HumanoidRootPart") or monster:FindFirstChildWhichIsA("BasePart")
            if mHrp then if (centerPos - mHrp.Position).Magnitude <= 100 then count = count + 1 end end
        end
    end
    return count
end

