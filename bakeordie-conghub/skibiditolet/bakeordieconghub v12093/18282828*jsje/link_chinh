-- LOGIC GLOBAL BRING ITEMS
task.spawn(function()
    local FixedCFrame = nil
    local LastBringType = nil 
    
    while true do
        task.wait(0.15)
        if not _G.GlobalBringActive then FixedCFrame = nil continue end
        if LastBringType ~= SelectedBringType then FixedCFrame = nil LastBringType = SelectedBringType end
        
        local character = lp.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        
        if rootPart and InteractablesFolder then
            if not FixedCFrame then FixedCFrame = rootPart.CFrame end
            
            for _, obj in pairs(InteractablesFolder:GetChildren()) do
                if not _G.GlobalBringActive then break end
                
                if SelectedBringType == "Vật liệu" then
                    if not IsInWhitelist(obj.Name) then continue end
                    local currentPosition = obj:GetPivot().Position
                    if currentPosition and (currentPosition - FixedCFrame.Position).Magnitude > 5 then
                        if obj:IsA("Model") then obj:PivotTo(FixedCFrame) else obj.CFrame = FixedCFrame end
                        pcall(function()
                            local mainPart = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildOfClass("BasePart")) or obj
                            if mainPart then mainPart.AssemblyLinearVelocity = Vector3.new(0,0,0) mainPart.AssemblyAngularVelocity = Vector3.new(0,0,0) end
                        end)
                        task.wait(0.005)
                    end
                    
                elseif SelectedBringType == "Xác Zombie" then
                    if not IsTargetMob(obj.Name) then continue end
                    local targetPart = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildOfClass("BasePart")) or obj
                    if targetPart and typeof(targetPart) == "Instance" and targetPart:IsA("BasePart") and (targetPart.Position - FixedCFrame.Position).Magnitude > 7 then
                        pcall(function()
                            targetPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                            targetPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                            local hum = obj:FindFirstChildOfClass("Humanoid")
                            if hum then hum:ChangeState(Enum.HumanoidStateType.Physics) end
                        end)
                        if obj:IsA("Model") and obj.PrimaryPart then obj:SetPrimaryPartCFrame(FixedCFrame) else targetPart.CFrame = FixedCFrame end
                        task.wait(0.05)
                    end
                    
                elseif SelectedBringType == "Đồ y tế" then
                    if not (obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("Model")) then continue end
                    local nameLower = obj.Name:lower()
                    if nameLower ~= "bandage" and nameLower ~= "firstaidkit" and nameLower ~= "revivekit" then continue end
                    
                    local currentPosition = obj:GetPivot().Position
                    if currentPosition and (currentPosition - FixedCFrame.Position).Magnitude > 5 then
                        if obj:IsA("Model") then obj:PivotTo(FixedCFrame) else obj.CFrame = FixedCFrame end
                        pcall(function()
                            local mainPart = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildOfClass("BasePart")) or obj
                            if mainPart then mainPart.AssemblyLinearVelocity = Vector3.new(0,0,0) mainPart.AssemblyAngularVelocity = Vector3.new(0,0,0) end
                        end)
                        task.wait(0.1)
                    end
                    
                elseif SelectedBringType == "Súng & Nước" then
                    if not ((obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("Model")) and IsWeapon(obj.Name)) then continue end
                    BringToPosition(obj, FixedCFrame)
                    task.wait(0.1)
                    
                elseif SelectedBringType == "Thịt" then
                    if not ((obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("Model")) and IsMeat(obj.Name)) then continue end
                    local currentPosition = obj:GetPivot().Position
                    if currentPosition and (currentPosition - FixedCFrame.Position).Magnitude > 5 then
                        if obj:IsA("Model") then obj:PivotTo(FixedCFrame) else obj.CFrame = FixedCFrame end
                        pcall(function()
                            local mainPart = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildOfClass("BasePart")) or obj
                            if mainPart then mainPart.AssemblyLinearVelocity = Vector3.new(0,0,0) mainPart.AssemblyAngularVelocity = Vector3.new(0,0,0) end
                        end)
                        task.wait(0.005)
                    end
                end
            end
        else
            FixedCFrame = nil
        end
    end
end)

-- LOGIC AUTO DAYS
local POS_SKIP = Vector3.new(-37.91, 51.59, 86.33)
local POS_TREO = Vector3.new(-26.95, 145, 122.67)
local previousFarmStateForSkip = false 
local wasAutoSkipActive = false        

local function ClickSkip()
    if _G.AutoSkip then
        if not wasAutoSkipActive then
            wasAutoSkipActive = true
            previousFarmStateForSkip = _G.AutoFarm 
            _G.AutoFarm = true                    
        end
    else
        if wasAutoSkipActive then _G.AutoFarm = previousFarmStateForSkip wasAutoSkipActive = false end
        return false
    end
    for _, v in pairs(Workspace:GetDescendants()) do
        if (v:IsA("ProximityPrompt") or v:IsA("ClickDetector")) then
            local parent = v:FindFirstAncestorWhichIsA("BasePart") or v:FindFirstAncestorWhichIsA("Attachment")
            if parent then
                local targetPos = parent:IsA("Attachment") and parent.WorldPosition or parent.Position
                if (targetPos - POS_SKIP).Magnitude < 15 then
                    if v:IsA("ProximityPrompt") then v.HoldDuration = 0 fireproximityprompt(v) else fireclickdetector(v) end
                    task.wait(0.1)
                    return true
                end
            end
        end
    end
    return false
end

task.spawn(function()
    local skippedForToday = false
    while true do
        task.wait(0.5)
        if _G.AutoLoopActive then
            local char = lp.Character
            local RootPart = char and char:FindFirstChild("HumanoidRootPart")
            local stations = Workspace:FindFirstChild("Stations")
            local openSign = stations and stations:FindFirstChild("OpenSign")
            local switchPart = openSign and openSign:FindFirstChild("Switch")
            
            if switchPart and switchPart:IsA("BasePart") then switchPart.CFrame = CFrame.new(POS_TREO) end

            if RootPart then
                local hour = Lighting.ClockTime
                if hour >= 6 and hour < 18 then
                    if not skippedForToday then
                        RootPart.CFrame = CFrame.new(POS_SKIP)
                        task.wait(0.4)
                        if ClickSkip() then skippedForToday = true RootPart.CFrame = CFrame.new(POS_TREO) end
                    else
                        if (RootPart.Position - POS_TREO).Magnitude > 5 then RootPart.CFrame = CFrame.new(POS_TREO) end
                    end
                else
                    skippedForToday = false
                    if (RootPart.Position - POS_TREO).Magnitude > 5 then RootPart.CFrame = CFrame.new(POS_TREO) end
                end
            end
        else
            skippedForToday = false
            if wasAutoSkipActive then _G.AutoFarm = previousFarmStateForSkip wasAutoSkipActive = false end
        end
    end
end)

