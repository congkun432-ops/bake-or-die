TimeLabel.Position = UDim2.new(0, 0, 0, 175)
TimeLabel.Text = "Đang lấy thời gian hệ thống..."
TimeLabel.TextColor3 = Color3.fromRGB(255, 180, 0)
TimeLabel.Font = Enum.Font.GothamMedium
TimeLabel.TextSize = 16
TimeLabel.BackgroundTransparency = 1

local TIME1  = 17 
local TIME2 = 0  

task.spawn(function()
    while ScreenGui and ScreenGui.Parent do
        local dateTable = os.date("!*t", os.time() + 7 * 3600)
        local currentSeconds = (dateTable.hour * 3600) + (dateTable.min * 60) + dateTable.sec
        local targetSeconds = (TIME1 * 3600) + (TIME2 * 60)
        local timeRemaining = targetSeconds - currentSeconds
        if timeRemaining < 0 then
            timeRemaining = timeRemaining + 86400
        end
        local hours = math.floor(timeRemaining / 3600)
        local minutes = math.floor((timeRemaining % 3600) / 60)
        local seconds = timeRemaining % 60
        TimeLabel.Text = string.format("Thời gian mở: %02d giờ %02d phút %02d giây", hours, minutes, seconds)
        task.wait(1)
    end
end)

