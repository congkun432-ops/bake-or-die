                        end
                    end
                end
            end
        else
            for _, v in pairs(workspace:GetDescendants()) do
                local esp = v:FindFirstChild("ChestVisual")
                if esp then esp:Destroy() end
            end
        end
        task.wait(5)
    end
end)


