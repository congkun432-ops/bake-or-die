local function CreateTab(name, isFirst)
    tabCount = tabCount + 1
    local TabBtn = Instance.new("TextButton", TabListFrame)
    TabBtn.Name = name .. "_Btn"
    TabBtn.LayoutOrder = tabCount 
    TabBtn.Size = UDim2.new(0.9, 0, 0, 35)
    TabBtn.BackgroundColor3 = isFirst and Theme.Accent or Color3.fromRGB(30, 30, 35)
    TabBtn.Text = name
    TabBtn.TextColor3 = isFirst and Color3.new(0,0,0) or Color3.new(1,1,1)
    TabBtn.Font = Enum.Font.GothamBold
    TabBtn.TextSize = 11
    Instance.new("UICorner", TabBtn)
    local T = Instance.new("ScrollingFrame", TabHold)
    T.Name = name .. "_Tab"
    T.Size = UDim2.new(1, 0, 1, 0)
    T.BackgroundTransparency = 1
    T.Visible = isFirst
    T.ScrollBarThickness = 0
    T.CanvasSize = UDim2.new(0, 0, 0, 800) 
    local L = Instance.new("UIListLayout", T)
    L.Padding = UDim.new(0, 10)
    L.HorizontalAlignment = "Center"
TabBtn.MouseButton1Click:Connect(function()
        for _, v in pairs(TabHold:GetChildren()) do 
            if v:IsA("ScrollingFrame") then v.Visible = false end 
        end
        for _, v in pairs(TabListFrame:GetChildren()) do 
            if v:IsA("TextButton") then 
                v.BackgroundColor3 = Color3.fromRGB(30, 30, 35) 
                v.TextColor3 = Color3.new(1,1,1)
            end 
        end
        T.Visible = true
        TabBtn.BackgroundColor3 = Theme.Accent
        TabBtn.TextColor3 = Color3.new(0,0,0)
    end)

    return T
end

