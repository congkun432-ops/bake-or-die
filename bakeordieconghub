    while task.wait(0.7) do
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local MasterList = {}
        if _G.BringWood then for _, v in pairs(ListWood) do table.insert(MasterList, v) end end
        if _G.BringZombie then for _, v in pairs(ListZombie) do table.insert(MasterList, v) end end
        if _G.BringIron then for _, v in pairs(ListIron) do table.insert(MasterList, v) end end
        if _G.BringMed then for _, v in pairs(ListMed) do table.insert(MasterList, v) end end

