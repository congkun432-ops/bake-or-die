task.spawn(function()
    while task.wait(1) do
        if _G.AutoBlueprintMaster then
            for i, step in ipairs(BlueprintSequence) do
                if not _G.AutoBlueprintMaster then break end
                
                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then continue end
                local targetPos = (type(step.Pos) == "table") and step.Pos[1] or step.Pos
                hrp.CFrame = CFrame.new(targetPos + Vector3.new(0, 2, 0))
                task.wait(1) 
                
                if step.Type == "Farm" then
                    if i == 1 then
                        local brought = false
                        for _, v in pairs(workspace:GetChildren()) do
                            if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") and IsEnemy(v) then
                                local mRoot = v.HumanoidRootPart
                                if (mRoot.Position - hrp.Position).Magnitude < 150 then
                                    mRoot.CanCollide = false
                                    mRoot.CFrame = hrp.CFrame * CFrame.new(0, 0, -5)
                                    brought = true
                                end
                            end
                        end
                    end
                    repeat
                        task.wait(1)
                        local mobCount = 0
                        for _, v in pairs(workspace:GetChildren()) do
                            if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") and IsEnemy(v) then
                                if (v.HumanoidRootPart.Position - hrp.Position).Magnitude < 100 then
                                    mobCount = mobCount + 1
                                end
                            end
                        end
                    until mobCount == 0 or not _G.AutoBlueprintMaster
                    
                elseif step.Type == "Collect" or step.Type == "GetCode" or step.Type == "Final" then
                    local positions = (type(step.Pos) == "table") and step.Pos or {step.Pos}
                    for _, p in ipairs(positions) do
                        hrp.CFrame = CFrame.new(p)
                        NotifyOn("six seven", "Đang tương tác...")
                        local startTime = tick()
                        repeat
                            task.wait(0.1)
                            pcall(function()
                                for _, v in pairs(workspace:GetDescendants()) do
                                    if v:IsA("ProximityPrompt") then
                                        local dist = (hrp.Position - (v.Parent:IsA("Model") and v.Parent:GetModelCFrame().p or v.Parent.Position)).Magnitude
                                        if dist < 20 then
                                            v.HoldDuration = 0
                                            fireproximityprompt(v)
                                        end
                                    end
                                end
                            end)
                        until tick() - startTime > 2
                        task.wait(0.5)
                    end
                end
                
                NotifyOn("six seven", "Bước " .. i .. " hoàn tất!")
            end
            _G.AutoBlueprintMaster = false
            NotifyOn("six seven", "Hoàn thành toàn bộ thiết kế!")
        end
    end
end)

